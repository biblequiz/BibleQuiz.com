---
import { TabItemTagname } from "./rehype-tabs";

interface Props {
    icon?: string;
    label: string;
    padding?: number;
}

const { label, icon, padding } = Astro.props as Props;

if (!label) {
    throw new Error("Missing prop `label` on `<TabItem>` component.");
}
---

<TabItemTagname data-label={label} data-icon={icon} data-padding={padding}>
    <slot />
</TabItemTagname>

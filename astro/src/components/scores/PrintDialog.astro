---
import { PrintDialogModalId } from "./PrintDialogContent";
import PrintDialogContent from "./PrintDialogContent";

interface Props {
    eventName: string;
}

const { eventName } = Astro.props as Props;
---

<dialog id={PrintDialogModalId} class="modal">
    <div class="modal-box w-full max-w-5xl">
        <form method="dialog">
            <button
                class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2"
                >✕</button
            >
        </form>
        <PrintDialogContent eventName={eventName} client:only="react" />
    </div>
</dialog>

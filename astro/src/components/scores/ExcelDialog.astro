---
import { ExcelDialogModalId } from "./ExcelDialogContent";
import ExcelDialogContent from "./ExcelDialogContent";

interface Props {
    eventName: string;
}

const { eventName } = Astro.props as Props;
---

<dialog id={ExcelDialogModalId} class="modal">
    <div class="modal-box w-full max-w-5xl">
        <form method="dialog">
            <button
                class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2"
                >✕</button
            >
        </form>
        <ExcelDialogContent eventName={eventName} client:only="react" />
    </div>
</dialog>

---
import { icon, type IconDefinition } from "@fortawesome/fontawesome-svg-core";
import "@fortawesome/fontawesome-svg-core/styles.css";

interface Props {
    icon: string;
    class?: string;
}

const iconSegments: string[] = Astro.props.icon.split(" ");
if (iconSegments.length !== 2) {
    throw new Error(
        `Invalid icon format: ${Astro.props.icon}. Expected format is "prefix iconName".`,
    );
}

let resolvedIcon: IconDefinition | null = null;
switch (iconSegments[0]) {
    case "fab":
    case "fa-brands":
        const BrandIcons = await import("@fortawesome/free-brands-svg-icons");
        resolvedIcon = BrandIcons[
            iconSegments[1] as keyof typeof BrandIcons
        ] as IconDefinition;
        break;
    case "far":
    case "fa-regular":
        const RegularIcons = await import(
            "@fortawesome/free-regular-svg-icons"
        );
        resolvedIcon = RegularIcons[
            iconSegments[1] as keyof typeof RegularIcons
        ] as IconDefinition;
        break;
    case "fas":
    case "fa-solid":
        const SolidIcons = await import("@fortawesome/free-solid-svg-icons");
        resolvedIcon = SolidIcons[
            iconSegments[1] as keyof typeof SolidIcons
        ] as IconDefinition;
        break;
    default:
        throw new Error(
            `Invalid icon prefix: ${iconSegments[0]}. Expected "fab", "far", or "fas".`,
        );
}

if (!resolvedIcon) {
    throw new Error(
        `Icon not found: ${iconSegments[1]}. If you copied the name from FontAwesome.com, make sure to remove all the dashes and make the character after the dash upper case (e.g., "fa-battle-net" becomes "faBattleNet").`,
    );
}

const iconHtml = icon(resolvedIcon, {
    classes: Array.from(new Set(Astro.props.class?.split(" "))),
}).html;
---

<Fragment set:html={iconHtml} />

---
import GlobalStatusToast from './GlobalStatusToast';
import packageJson from '../../package.json';

const packageVersion = packageJson.version ?? "unknown";
const appInsightsConnectionString = import.meta.env.PUBLIC_APPINSIGHTS_CONNECTION_STRING ?? "";
---

<GlobalStatusToast client:only="react" />

<script is:inline define:vars={{ packageVersion, appInsightsConnectionString }}>
    window.__bqGlobalTelemetryConfig = {
        packageVersion,
        appInsightsConnectionString,
    };
</script>

<script>
    import { setupGlobalNotificationManager } from "../utils/setupGlobalNotificationManager";

    const config = window.__bqGlobalTelemetryConfig ?? {
        packageVersion: "unknown",
        appInsightsConnectionString: "",
    };

    setupGlobalNotificationManager(config);
</script>

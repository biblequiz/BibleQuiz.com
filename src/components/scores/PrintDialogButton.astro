---
import { PrintDialogModalId } from "./PrintDialogContent";
import FontAwesomeIcon from "components/FontAwesomeIcon";

interface Props {
    isLoaded: boolean;
}

const { isLoaded } = Astro.props as Props;
---

<button
    type="button"
    id={`${PrintDialogModalId}-button`}
    class="btn btn-outline cursor-pointer hide-on-print whitespace-nowrap"
    disabled={!isLoaded}
>
    <FontAwesomeIcon icon="fas faPrint" />
    <span>Print</span>
</button>
